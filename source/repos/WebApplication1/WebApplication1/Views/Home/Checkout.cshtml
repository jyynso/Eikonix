@model WebApplication1.Models.CheckoutViewModel
@{
    ViewBag.Title = "Checkout";
    Layout = "~/Views/Shared/_Layout_Cart.cshtml";
}

<link href="~/Content/Cart.css" rel="stylesheet" />

<div class="notification-container" id="notificationContainer"></div>

@* The container class is used for general page padding/max-width *@
<div class="content container">
    <h2 class="section-title">My Order</h2> @* Title matches the image/cart context *@

    @if (TempData["Error"] != null)
    {
        <div class="custom-alert-box error mb-4">
            <i class='bx bxs-error-alt'></i>
            <div class="alert-content">
                <p class="alert-message">@TempData["Error"]</p>
            </div>
        </div>
    }

    <div class="checkout-wrapper">

        <div class="order-details-container">

            @* --- ITEMS LIST --- *@
            <div class="order-items-list">
                @foreach (var item in Model.CartItems)
                {
                    <div class="order-item-card">
                        <div class="item-card-left">
                            <img src="@Url.Content(item.ProductImage)" alt="@item.ProductTitle" class="item-card-img">
                        </div>
                        <div class="item-card-middle">
                            <h4 class="item-title">@item.ProductTitle</h4>
                            <p class="item-artist">by @item.ProductArtist</p>
                            <p class="item-size">Size: @item.ProductSize</p>  
                            <p class="item-stock">In Stock  </p>

                            <div class="item-action-row">
                                <a href="@Url.Action("Cart")" class="item-action-link">Edit</a>
                                <a href="#" class="item-action-link remove">Remove</a> 
                            </div>
                        </div>
                        <div class="item-card-right">
                            <div class="item-info-row">
                                <span class="label">Price</span>
                                <span class="value price">₱@item.Price.ToString("N2")</span>
                            </div>
                            <div class="item-info-row quantity-row">
                                <span class="label">Quantity</span>
                                <span class="value quantity">@item.ProductStock</span> 
                            </div>
                            <div class="item-info-row total-row">
                                <span class="label">Total</span>
                                <span class="value total-price">₱@item.ItemTotal.ToString("N2")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="item-count-summary">
                <span class="count-text">@Model.CartItems.Count() @(Model.CartItems.Count() == 1 ? "Item" : "Items")</span>
                <span class="count-total">₱@Model.TotalAmount.ToString("N2")</span>
            </div>
        </div>

        <div class="order-summary-panel">
            <div class="promo-section">
                <h4 class="promo-title">ENTER PROMO CODE</h4>
                <div class="promo-input-group">
                    <input type="text" placeholder="Promo Code" class="promo-input">
                    <button type="button" class="promo-submit-btn">Submit</button>
                </div>
            </div>

            <div class="totals-section">
                <div class="summary-row">
                    <span class="summary-label">Subtotal</span>
                    <span class="summary-value">₱@Model.TotalAmount.ToString("N2")</span>
                </div>
                <div class="summary-row">
                    <span class="summary-label">Shipping Fee</span>
                    @*wala eh, lets just pretend this works cause I dont want to work on the db anymore :(*@
                    <span class="summary-value">₱40.00</span>
                </div>
                <div class="summary-row discount-row">
                    <span class="summary-label">Discount</span>
                    @*wala eh, lets just pretend this works cause I dont want to work on the db anymore :(*@
                    <span class="summary-value discounted">-₱40.00</span> 
                </div>
                <div class="summary-row payment-method-row">
                    <span class="summary-label">Payment Method</span>
                    <span class="summary-value">Gcash</span> 
                </div>
            </div>

            <div class="grand-total">
                <span class="grand-total-label">TOTAL</span>
                <span class="grand-total-price">₱@Model.TotalAmount.ToString("N2")</span>
            </div>

            @using (Html.BeginForm("ProcessOrder", "Home", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <button type="submit" class="btn-buy checkout-btn-place-order">
                    Place Order
                </button>
            }

        </div>
    </div>
</div>

<script src="@Url.Content("~/Scripts/main2.js")"></script>
<script src="@Url.Content("~/Scripts/theme-toggle.js")"></script>