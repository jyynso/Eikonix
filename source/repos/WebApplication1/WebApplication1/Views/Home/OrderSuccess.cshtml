@{
    ViewBag.Title = "Home";
    Layout = "~/Views/Shared/_Layout_Cart.cshtml";
}

<style>
    :root {
        --main-color: #00FFFF;
        --second-color: #008080;
        --text-color: #1b1b1b;
        --bg-color: #F3FFFF;
        --accent-color: #003333;
        --box-shadow: 0 8px 32px rgba(0, 255, 255, 0.15);
        --gradient-primary: linear-gradient(135deg, #00FFFF 0%, #008080 100%);
        --gradient-secondary: linear-gradient(135deg, #008080 0%, #003333 100%);
        --header-gradient: linear-gradient(90deg, #008B8B 0%, #00A0A0 50%, #00B8B8 100%);
        --card-bg: #ffffff;
        --input-bg: #ffffff;
        --border-color: rgba(0, 255, 255, 0.2);
    }

    .order-success-container {
        background: var(--bg-color);
        display: flex;
        flex-direction: row;
        padding: 50px;
        gap: 100px;
        height: 400px;
    }
    .home-img {
        height: 50%;
        width: 50%;
    }
    .header {
        color: var(--text-color);
        font-size: 50px;
        font-weight: 600;
    }
    .order-success-container-right {
        display: flex;
        flex-direction: column;
    }
    .to-cart-button {
        padding: 20px;
        justify-content: center;    
    }
</style>

<div class="order-success-container">
    <div class="home-img">
        <div class="image-wrapper">
            <img src="~/Content/imgs/About/home-img.png" alt="Featured Artwork">
        </div>
    </div>

    <div class="order-success-container-right">
        <h1 class="header">THANK YOU FOR YOUR PURCHASE!</h1>

        <div class="to-cart-button">
            <a href="@Url.Action("Cart", "Home")" class="btn btn-primary">
                <i class='bx bx-log-in'></i>
                Back to Cart
            </a>
        </div>
    </div>

    
</div>
