@model WebApplication1.Models.AdminDashboardView
@{
    Layout = null;
    ViewBag.Title = "Sales Reports";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales Reports - Eikonix</title>
    <link rel="stylesheet" href="@Url.Content("~/Content/Admin.css")" />
    <link rel="stylesheet" href="https://unpkg.com/boxicons@latest/css/boxicons.min.css">
    <link rel="icon" type="image/png" href="@Url.Content("~/Content/imgs/Logo/favicon.png")" />
</head>
<body>
    <!-- DARK MODE TOGGLE BUTTON -->
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle Dark Mode">
        <i class='bx bx-moon' id="themeIcon"></i>
    </button>

    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="admin-logo-section">
            <img src="~/Content/imgs/Logo/logof.png" alt="Eikonix Logo" class="admin-logo">
            <h1 class="admin-brand-name">EIKONIX</h1>
            <p class="admin-brand-tagline">Admin Portal</p>
        </div>
        <ul>
            <li><a href="@Url.Action("Dashboard", "Admin")"><i class='bx bxs-dashboard'></i> Dashboard</a></li>
            <li><a href="@Url.Action("ManageProducts", "Admin")"><i class='bx bx-box'></i> Manage Products</a></li>
            <li><a href="@Url.Action("ManageOrders", "Admin")"><i class='bx bx-cart'></i> Manage Orders</a></li>
            <li><a href="@Url.Action("ManageCustomers", "Admin")"><i class='bx bx-user'></i> Manage Customers</a></li>
            <li><a href="@Url.Action("SalesReports", "Admin")" class="active"><i class='bx bx-line-chart'></i> Sales Reports</a></li>
            <li><a href="@Url.Action("Logout", "Account")" class="logout-btn"><i class='bx bx-log-out'></i> Logout</a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="admin-content">
        <div class="admin-header">
            <h1>Sales Reports</h1>
            <div class="user-info">
                <i class='bx bx-user-circle' style="font-size: 1.5rem;"></i>
                <span>@ViewBag.CurrentAdminEmail</span>
            </div>
        </div>

        <!-- Summary Cards -->
        <div class="dashboard-cards">
            <div class="dashboard-card">
                <i class='bx bx-dollar-circle'></i>
                <h3>Total Sales</h3>
                <p>&#8369;@Model.TotalSales</p>
            </div>

            <div class="dashboard-card">
                <i class='bx bx-cart'></i>
                <h3>Total Orders</h3>
                <p>@Model.TotalProducts</p>
            </div>

            <div class="dashboard-card">
                <i class='bx bx-user'></i>
                <h3>Total Customers</h3>
                <p>@Model.TotalCustomers</p>
            </div>

            <div class="dashboard-card">
                <i class='bx bx-trending-up'></i>
                <h3>Avg Order Value</h3>
                <p>&#8369;@Model.AvgOrderValue</p>
            </div>
        </div>

        <!-- Monthly Sales -->
        <div class="admin-table-container" style="margin-bottom: 30px;">
            <h2>Monthly Sales Summary</h2>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Month</th>
                        <th>Total Orders</th>
                        <th>Total Sales</th>
                        <th>New Customers</th>
                        <th>Growth</th>
                    </tr>
                </thead>
                <tbody>
                        @foreach (var details in Model.MonthSummaryView)
                        {
                            decimal growthPercent = details.Growth * 100m;
                            string growthClass = "";

                            if (details.Growth < 5.0m)
                            {
                                growthClass = "status-processing";
                            }
                            else if (details.Growth >= 5.0m)
                            {
                                growthClass = "status-completed";
                            }
                            <tr>
                                <td>@details.Month</td>
                                <td>@details.TotalOrders</td>
                                <td>&#8369;@details.TotalSales</td>
                                <td>@details.NewCustomers</td>
                                <td><span class="status-badge @growthClass">+@details.Growth%</span></td>
                            </tr>
                        }

                </tbody>
            </table>
        </div>

        <!-- Top Products -->
        <div class="admin-table-container" style="margin-bottom: 30px;">
            <h2>Top Selling Artworks</h2>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Artwork Name</th>
                        <th>Category</th>
                        <th>Units Sold</th>
                        <th>Revenue</th>
                        <th>Performance</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var details in Model.TopProducts)
                    {
                        //the responsive css class @performanceClass is in the adminController on this one sry for inconsistency I forgor. It works just fine, leave it be
                        <tr>
                            <td>@details.Rank</td>
                            <td>@details.ArtworkName</td>
                            <td>@details.Category</td>
                            <td>@details.UnitsSold</td>
                            <td>&#8369;@details.Revenue</td>
                            <td><span class="status-badge @details.PerformanceClass">@details.PerformanceLabel</span></td>
                        </tr>   
                    }
                </tbody>
            </table>
        </div>

        <!-- Category Performance -->
        <div class="admin-table-container">
            <h2>Category Performance</h2>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Category</th>
                        <th>Total Products</th>
                        <th>Units Sold</th>
                        <th>Total Revenue</th>
                        <th>Avg Price</th>
                        <th>Market Share</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var details in Model.CategoryPerformance)
                    {
                        <tr>
                            <td>@details.CategoryName   </td>
                            <td>@details.TotalProducts</td>
                            <td>@details.TotalUnitsSold</td>
                            <td>&#8369;@details.TotalRevenue</td>
                            <td>&#8369;@details.AveragePrice</td>
                            <td><span class="status-badge status-completed">@details.MarketSharePercentage.ToString("0.0")%</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <script src="@Url.Content("~/Scripts/theme-toggle.js")"></script>
</body>
</html>
