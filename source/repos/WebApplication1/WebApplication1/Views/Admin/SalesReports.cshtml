@{
    Layout = null;
    ViewBag.Title = "Sales Reports";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales Reports - Eikonix</title>
    <link rel="stylesheet" href="@Url.Content("~/Content/Admin.css")" />
    <link rel="stylesheet" href="https://unpkg.com/boxicons@latest/css/boxicons.min.css">
</head>
<body>
    <!-- DARK MODE TOGGLE BUTTON -->
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle Dark Mode">
        <i class='bx bx-moon' id="themeIcon"></i>
    </button>

    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="admin-logo-section">
            <img src="~/Content/imgs/Logo/logof.png" alt="Eikonix Logo" class="admin-logo">
            <h1 class="admin-brand-name">EIKONIX</h1>
            <p class="admin-brand-tagline">Admin Portal</p>
        </div>
        <ul>
            <li><a href="@Url.Action("Dashboard", "Admin")"><i class='bx bxs-dashboard'></i> Dashboard</a></li>
            <li><a href="@Url.Action("ManageProducts", "Admin")"><i class='bx bx-box'></i> Manage Products</a></li>
            <li><a href="@Url.Action("ManageOrders", "Admin")"><i class='bx bx-cart'></i> Manage Orders</a></li>
            <li><a href="@Url.Action("ManageCustomers", "Admin")"><i class='bx bx-user'></i> Manage Customers</a></li>
            <li><a href="@Url.Action("SalesReports", "Admin")" class="active"><i class='bx bx-line-chart'></i> Sales Reports</a></li>
            <li><a href="@Url.Action("Logout", "Account")" class="logout-btn"><i class='bx bx-log-out'></i> Logout</a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="admin-content">
        <div class="admin-header">
            <h1>Sales Reports</h1>
            <div class="user-info">
                <i class='bx bx-user-circle' style="font-size: 1.5rem;"></i>
                <span>admin@gmail.com</span>
            </div>
        </div>

        <!-- Summary Cards -->
        <div class="dashboard-cards">
            <div class="dashboard-card">
                <i class='bx bx-dollar-circle'></i>
                <h3>Total Sales</h3>
                <p>&#8369;156,890.00</p>
            </div>

            <div class="dashboard-card">
                <i class='bx bx-cart'></i>
                <h3>Total Orders</h3>
                <p>156</p>
            </div>

            <div class="dashboard-card">
                <i class='bx bx-user'></i>
                <h3>Total Customers</h3>
                <p>89</p>
            </div>

            <div class="dashboard-card">
                <i class='bx bx-trending-up'></i>
                <h3>Avg Order Value</h3>
                <p>&#8369;1,005.70</p>
            </div>
        </div>

        <!-- Monthly Sales -->
        <div class="admin-table-container" style="margin-bottom: 30px;">
            <h2>Monthly Sales Summary</h2>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Month</th>
                        <th>Total Orders</th>
                        <th>Total Sales</th>
                        <th>New Customers</th>
                        <th>Growth</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>January 2024</td>
                        <td>156</td>
                        <td>&#8369;156,890.00</td>
                        <td>23</td>
                        <td><span class="status-badge status-completed">+12.5%</span></td>
                    </tr>
                    <tr>
                        <td>December 2023</td>
                        <td>189</td>
                        <td>&#8369;198,450.00</td>
                        <td>31</td>
                        <td><span class="status-badge status-completed">+18.3%</span></td>
                    </tr>
                    <tr>
                        <td>November 2023</td>
                        <td>145</td>
                        <td>&#8369;142,100.00</td>
                        <td>19</td>
                        <td><span class="status-badge status-completed">+8.7%</span></td>
                    </tr>
                    <tr>
                        <td>October 2023</td>
                        <td>132</td>
                        <td>&#8369;128,750.00</td>
                        <td>15</td>
                        <td><span class="status-badge status-completed">+5.2%</span></td>
                    </tr>
                    <tr>
                        <td>September 2023</td>
                        <td>128</td>
                        <td>&#8369;117,480.00</td>
                        <td>12</td>
                        <td><span class="status-badge status-processing">+2.1%</span></td>
                    </tr>
                    <tr>
                        <td>August 2023</td>
                        <td>142</td>
                        <td>&#8369;141,650.00</td>
                        <td>18</td>
                        <td><span class="status-badge status-completed">+11.4%</span></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Top Products -->
        <div class="admin-table-container" style="margin-bottom: 30px;">
            <h2>Top Selling Artworks</h2>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Rank</th>
                        <th>Artwork Name</th>
                        <th>Category</th>
                        <th>Units Sold</th>
                        <th>Revenue</th>
                        <th>Performance</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td>Fantasy Realm</td>
                        <td>Digital Art</td>
                        <td>45</td>
                        <td>&#8369;225,000.00</td>
                        <td><span class="status-badge status-completed">Excellent</span></td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td>Urban Landscape</td>
                        <td>Traditional Art</td>
                        <td>38</td>
                        <td>&#8369;171,000.00</td>
                        <td><span class="status-badge status-completed">Excellent</span></td>
                    </tr>
                    <tr>
                        <td>3</td>
                        <td>Cyberpunk City</td>
                        <td>Digital Art</td>
                        <td>32</td>
                        <td>&#8369;134,400.00</td>
                        <td><span class="status-badge status-completed">Excellent</span></td>
                    </tr>
                    <tr>
                        <td>4</td>
                        <td>Portrait Study</td>
                        <td>Traditional Art</td>
                        <td>28</td>
                        <td>&#8369;106,400.00</td>
                        <td><span class="status-badge status-processing">Good</span></td>
                    </tr>
                    <tr>
                        <td>5</td>
                        <td>Mountain Majesty</td>
                        <td>Traditional Art</td>
                        <td>25</td>
                        <td>&#8369;87,500.00</td>
                        <td><span class="status-badge status-processing">Good</span></td>
                    </tr>
                    <tr>
                        <td>6</td>
                        <td>Abstract Emotions</td>
                        <td>Traditional Art</td>
                        <td>22</td>
                        <td>&#8369;70,400.00</td>
                        <td><span class="status-badge status-processing">Good</span></td>
                    </tr>
                    <tr>
                        <td>7</td>
                        <td>Neon Nights</td>
                        <td>Digital Art</td>
                        <td>20</td>
                        <td>&#8369;56,000.00</td>
                        <td><span class="status-badge status-processing">Good</span></td>
                    </tr>
                    <tr>
                        <td>8</td>
                        <td>Sunset Dreams</td>
                        <td>Digital Art</td>
                        <td>18</td>
                        <td>&#8369;45,000.00</td>
                        <td><span class="status-badge status-pending">Average</span></td>
                    </tr>
                    <tr>
                        <td>9</td>
                        <td>Still Life Collection</td>
                        <td>Traditional Art</td>
                        <td>15</td>
                        <td>&#8369;33,000.00</td>
                        <td><span class="status-badge status-pending">Average</span></td>
                    </tr>
                    <tr>
                        <td>10</td>
                        <td>Floral Paradise</td>
                        <td>Digital Art</td>
                        <td>12</td>
                        <td>&#8369;25,200.00</td>
                        <td><span class="status-badge status-pending">Average</span></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Category Performance -->
        <div class="admin-table-container">
            <h2>Category Performance</h2>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Category</th>
                        <th>Total Products</th>
                        <th>Units Sold</th>
                        <th>Total Revenue</th>
                        <th>Avg Price</th>
                        <th>Market Share</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Digital Art</td>
                        <td>6</td>
                        <td>127</td>
                        <td>&#8369;485,600.00</td>
                        <td>&#8369;3,824.41</td>
                        <td><span class="status-badge status-completed">58.2%</span></td>
                    </tr>
                    <tr>
                        <td>Traditional Art</td>
                        <td>6</td>
                        <td>128</td>
                        <td>&#8369;468,300.00</td>
                        <td>&#8369;3,658.59</td>
                        <td><span class="status-badge status-completed">41.8%</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    <script src="@Url.Content("~/Scripts/theme-toggle.js")"></script>
</body>
</html>
