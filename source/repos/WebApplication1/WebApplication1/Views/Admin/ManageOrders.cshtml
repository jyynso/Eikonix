@model WebApplication1.Models.AdminDashboardView
@{
    Layout = null;
    ViewBag.Title = "Manage Orders";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Orders - Eikonix</title>
    <link rel="stylesheet" href="@Url.Content("~/Content/Admin.css")" />
    <link rel="stylesheet" href="https://unpkg.com/boxicons@latest/css/boxicons.min.css">
</head>

<body>
    <!-- DARK MODE TOGGLE BUTTON -->
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle Dark Mode">
        <i class='bx bx-moon' id="themeIcon"></i>
    </button>

    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="admin-logo-section">
            <img src="~/Content/imgs/Logo/logof.png" alt="Eikonix Logo" class="admin-logo">
            <h1 class="admin-brand-name">EIKONIX</h1>
            <p class="admin-brand-tagline">Admin Portal</p>
        </div>
        <ul>
            <li><a href="@Url.Action("Dashboard", "Admin")"><i class='bx bxs-dashboard'></i> Dashboard</a></li>
            <li><a href="@Url.Action("ManageProducts", "Admin")"><i class='bx bx-box'></i> Manage Products</a></li>
            <li>
                <a href="@Url.Action("ManageOrders", "Admin")" class="active"><i class='bx bx-cart'></i> Manage Orders</a>
            </li>
            <li><a href="@Url.Action("ManageCustomers", "Admin")"><i class='bx bx-user'></i> Manage Customers</a></li>
            <li><a href="@Url.Action("SalesReports", "Admin")"><i class='bx bx-line-chart'></i> Sales Reports</a></li>
            <li><a href="@Url.Action("Logout", "Account")" class="logout-btn"><i class='bx bx-log-out'></i> Logout</a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="admin-content">
        <div class="admin-header">
            <h1>Manage Orders</h1>
            <div class="user-info">
                <i class='bx bx-user-circle' style="font-size: 1.5rem;"></i>
                <span>@ViewBag.CurrentAdminEmail</span>
            </div>
        </div>

        <div class="admin-table-container">
            <h2>All Orders</h2>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Total Amount</th>
                        <th>Status</th>
                        <th>Order Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var details in Model.RecentOrders)
                    {
                        //throwing a nullexception at first so I added this
                        string status = string.IsNullOrEmpty(details.orderStatus)
                            ? "pending"
                            : details.orderStatus.ToLower();

                        string statusClass;

                        if (status.Contains("pending"))
                        {
                            statusClass = "status-pending";
                        }
                        else if (status.Contains("completed"))
                        {
                            statusClass = "status-completed";
                        }
                        else if (status.Contains("processing"))
                        {
                            statusClass = "status-processing";
                        }
                        else
                        {
                            statusClass = "default";
                        }
                        <tr>
                            <td>#@details.orderId</td>
                            <td>@details.userName</td>
                            <td>&#8369;@details.orderTotalAmount</td>
                            <td><span class="status-badge @statusClass">@details.orderStatus</span></td>
                            <td>@details.orderDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <button class="btn-admin btn-view">View</button>
                                <button class="btn-admin btn-edit">Update Status</button>
                                <button class="btn-admin btn-delete">Cancel</button>
                            </td>
                        </tr>

                    }
                </tbody>
            </table>
        </div>

        <div class="custom-modal-overlay" id="modalViewOrderDetails">
            <div class="custom-modal-content">

                <div class="modal-header-custom">
                    <h3 class="modal-title-custom" id="modalTitle">Order Details</h3>
                    <button class="close-btn-custom" id="closeButton">&times;</button>
                </div>

                <div class="modal-body-custom">
                    <p id="modalBodyText">Order Details</p>
                </div>

                <div class="modal-footer-custom">
                    <button class="btn-admin btn-secondary-custom" id="cancelButton">Cancel</button>
                    <button class="btn-admin" id="confirmButton">Confirm Change</button>
                </div>

            </div>
        </div>

    </div>
    <script src="@Url.Content("~/Scripts/theme-toggle.js")"></script>
</body>

</html>
