@model List<Eikonix.Models.Products>
@{

    var searchQuery = ViewBag.SearchQuery as string;

    ViewBag.Title = $"Search Results for: {searchQuery}";

    Layout = "~/Views/Shared/_Layout_Cart.cshtml";
}

<link href="~/Content/Cart.css" rel="stylesheet" />
<style>

    /*image modal*/
    .image-modal {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.7);
        z-index: 9999;
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.25s ease;
    }

        .image-modal img {
            width: auto;
            height: auto;
            max-width: 450px;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
            transform: scale(0.95);
            transition: transform 0.25s ease;
        }

        /* when modal is active */
        .image-modal.show {
            opacity: 1;
            visibility: visible;
        }

            .image-modal.show img {
                transform: scale(1);
            }
</style>

<!-- Cart Section -->
<div class="cart">
    <h2 class="cart-title">Your Cart</h2>

    <div class="cart-content">
        <!-- JS will populate items here -->
    </div>

    <div class="total">
        <div class="total-title">Total</div>
        <div class="total-price">₱0</div>
    </div>

    @*FIX3*@
    @*<form method="post" action="@Url.Action("Checkout", "Home")" id="checkoutForm">
            <button type="submit" class="btn-buy">Place Order</button>
        </form>*@

    <button type="submit" class="btn-buy">Place Order</button>
    <i class='bx bx-x' id="cart-close"></i>
</div>

<div class="content">

    <div class="notification-container" id="notificationContainer"></div>

    <section class="shop container">

        <h1 class="section-title">
            @if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                <text>Search Results for: "@searchQuery"</text>
            }
            else
            {
                <text>Product Search</text>
            }
        </h1>

        @if (Model == null || !Model.Any())
        {
            <div style="text-align: center; padding: 50px;">
                <i class="bx bx-error-circle" style="font-size: 3rem; color: var(--second-color);"></i>
                <h3 style="margin-top: 20px; color: var(--text-color);">No Result Found!</h3>
                <p style="color: var(--text-color); opacity: 0.8;">
                    We couldn't find any artworks matching your search query. Try searching for different keywords related to the title, artist, or description.
                </p>
            </div>
        }
        else
        {
            <div class="shop-content">
                @foreach (var product in Model)
                {
                    <div class="product-box" data-id="@product.productId">

                        <img src="@Url.Content(product.productImagePath.Trim())" alt="@product.productTitle" class="product-img">
                        <h2 class="product-title">@product.productTitle</h2>
                        <p class="product-title sub">Artist: @product.productArtist</p>
                        <p class="product-title sub">Description: @product.productDescription</p>
                        <p class="product-title sub">Category: @product.productCategory</p>
                        <p class="product-title sub">Medium: @product.productMedium</p>
                        <p class="product-title sub">Size: @product.productSize</p>
                        <p class="product-title sub">Stock: @product.productStock</p>

                        <span class="product-price">₱@product.productPrice.ToString("N2")</span>

                        <i class='bx bx-shopping-bag add-cart' data-id="@product.productId"></i>
                    </div>
                }
            </div>
        }
    </section>

    <section class="about" id="about">

        <h2 class="about-title">ABOUT US</h2>

        <div class="about-wrapper">

            <div class="about-left">
                <img src="~/Content/imgs/About/home-img.png" alt="about">
            </div>

            <div class="about-right">

                <div class="about-card wave1">
                    <h3>Welcome to Eikonix</h3>
                    <p>
                        Eikonix is a modern e-commerce platform dedicated to showcasing and selling
                        both traditional and digital artworks. We provide a professional online space
                        where emerging talents and established artists can present their creations to
                        a wider audience. As a creative marketplace, Eikonix aims to bridge the gap
                        between artists and art enthusiasts by offering a secure, organized, and visually
                        engaging environment for artistic exchange.
                    </p>
                </div>

                <div class="about-card wave2">
                    <h3>Our Purpose</h3>
                    <p>
                        At Eikonix, we believe that every artist deserves a place where their creativity
                        can thrive. Our platform supports the growth of artists—helping them gain visibility,
                        build their portfolio, and connect with buyers. Customers enjoy a curated browsing
                        experience where they can discover meaningful pieces reflecting their personality.
                    </p>
                </div>

            </div>
        </div>

    </section>

    <!-- Image Modal - Add this anywhere in your content section -->
    <div class="image-modal" id="imageModal">
        <img id="modalImage" src="" alt="Product Image">
    </div>
</div>
<script>
    const modal = document.getElementById("imageModal");
    const modalImg = document.getElementById("modalImage");

    document.querySelectorAll(".product-img").forEach(img => {
        img.addEventListener("click", () => {
            modalImg.src = img.src;
            modal.classList.add("show");
        });
    });

    modal.addEventListener("click", () => {
        modal.classList.remove("show");
    });
</script>